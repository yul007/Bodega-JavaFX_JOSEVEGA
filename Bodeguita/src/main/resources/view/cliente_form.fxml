<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21.0.0"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bodega.controller.ClienteFormController"
      spacing="14">
    <padding>
        <Insets top="18" right="18" bottom="18" left="18" />
    </padding>

    <children>
        <Label text="Formulario de cliente" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <GridPane hgap="12" vgap="12">
            <children>
                <Label text="Identificacion" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <TextField fx:id="identificacionField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefColumnCount="30" />

                <Label text="Nombre" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <TextField fx:id="nombreField" GridPane.rowIndex="1" GridPane.columnIndex="1" prefColumnCount="30" />

                <Label text="Telefono" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <TextField fx:id="telefonoField" GridPane.rowIndex="2" GridPane.columnIndex="1" prefColumnCount="30" />

                <Label text="Email" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <TextField fx:id="emailField" GridPane.rowIndex="3" GridPane.columnIndex="1" prefColumnCount="30" />

                <Label text="Direccion" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <TextField fx:id="direccionField" GridPane.rowIndex="4" GridPane.columnIndex="1" prefColumnCount="30" />
            </children>
        </GridPane>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar" />
                <Button fx:id="btnGuardar" text="Guardar" onAction="#onGuardar" defaultButton="true" />
            </children>
        </HBox>
    </children>
</VBox>
