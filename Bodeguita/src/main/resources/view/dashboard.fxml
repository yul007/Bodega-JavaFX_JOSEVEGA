<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bodega.controller.DashboardController">
    <top>
        <HBox spacing="10" alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10" />
            </padding>
            <children>
                <Label text="Dashboard" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" alignment="CENTER">
            <padding>
                <Insets top="10" bottom="10" />
            </padding>
            <children>
                <HBox spacing="20" alignment="CENTER">
                    <children>
                        <Label fx:id="lblValorInventario" text="Valor Total de Inventario: $0.00" />
                    </children>
                </HBox>

                <HBox spacing="20" alignment="CENTER">
                    <children>
                        <VBox spacing="10" alignment="CENTER">
                            <children>
                                <Label text="Productos con Stock Bajo" style="-fx-font-size: 14px; -fx-underline: true;" />
                                <TableView fx:id="tablaStockBajo" style="-fx-pref-width: 300;">
                                    <columns>
                                        <TableColumn text="Producto" fx:id="colProductoStock" />
                                        <TableColumn text="Stock Actual" fx:id="colStockActual" />
                                        <TableColumn text="Stock Mínimo" fx:id="colStockMinimo" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox spacing="10" alignment="CENTER">
                            <children>
                                <Label text="Top 5 Productos Más Vendidos" style="-fx-font-size: 14px; -fx-underline: true;" />
                                <PieChart fx:id="chartTopVendidos" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="20" alignment="CENTER">
                    <children>
                        <VBox spacing="10" alignment="CENTER">
                            <children>
                                <Label text="Ventas Últimos 30 Días" style="-fx-font-size: 14px; -fx-underline: true;" />
                                <LineChart fx:id="chartVentas30Dias">
                                    <xAxis>
                                        <CategoryAxis label="Días" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis label="Monto ($)" />
                                    </yAxis>
                                </LineChart>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="20" alignment="CENTER">
            <padding>
                <Insets top="10" bottom="10" />
            </padding>
            <children>
                <Button fx:id="btnActualizar" text="Actualizar" onAction="#onActualizar" />
                <Button fx:id="btnExportarReporte" text="Exportar Reporte" onAction="#onExportarReporte" />
            </children>
        </HBox>
    </bottom>
</BorderPane>