<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bodega.controller.ProveedorController">
    <top>
        <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #E0E0E0; -fx-padding: 10px;">
            <Label text="Gestión de Proveedores" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        </HBox>
    </top>
    
    <center>
        <VBox spacing="10" alignment="CENTER" padding="10">
            <TableView fx:id="proveedorTable" style="-fx-pref-width: 600;">
                <columns>
                    <TableColumn text="RUC" fx:id="colRuc" />
                    <TableColumn text="Nombre" fx:id="colNombre" />
                    <TableColumn text="Contacto" fx:id="colContacto" />
                    <TableColumn text="Teléfono" fx:id="colTelefono" />
                    <TableColumn text="Email" fx:id="colEmail" />
                </columns>
            </TableView>
            
            <HBox spacing="10" alignment="CENTER" padding="10">
                <Button fx:id="btnNuevoProveedor" text="Nuevo" onAction="#onNuevoProveedor" />
                <Button fx:id="btnEditarProveedor" text="Editar" onAction="#onEditarProveedor" />
                <Button fx:id="btnInactivarProveedor" text="Inactivar" onAction="#onInactivarProveedor" />
                <Button fx:id="btnRefrescar" text="Refrescar" onAction="#onRefrescar" />
            </HBox>
        </VBox>
    </center>
</BorderPane>