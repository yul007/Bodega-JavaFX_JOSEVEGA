<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650.0" prefWidth="1000.0" styleClass="module-shell" xmlns="http://javafx.com/javafx/21.0.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bodega.controller.ReporteController">
    <top>
        <VBox spacing="4.0" styleClass="header-bar">
            <padding>
                <Insets top="18.0" right="28.0" bottom="18.0" left="28.0" />
            </padding>
            <Label styleClass="screen-title" text="Gestión de Reportes" />
            <Label styleClass="screen-subtitle" text="Exportación CSV y TXT según filtros y periodos" />
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0" styleClass="module-content">
            <HBox spacing="12.0" styleClass="module-card">
                <Label text="Tipo de reporte:" />
                <ComboBox fx:id="comboTipoReporte" prefWidth="280.0" promptText="Seleccionar tipo de reporte" />
            </HBox>

            <HBox spacing="12.0" styleClass="module-card">
                <Label text="Producto:" />
                <ComboBox fx:id="comboProducto" prefWidth="260.0" promptText="Seleccionar producto" />
                <Label text="Proveedor:" />
                <ComboBox fx:id="comboProveedor" prefWidth="260.0" promptText="Seleccionar proveedor" />
                <Label text="Desde:" />
                <DatePicker fx:id="dateDesde" />
                <Label text="Hasta:" />
                <DatePicker fx:id="dateHasta" />
            </HBox>

            <HBox spacing="16.0" styleClass="module-card">
                <Button fx:id="btnExportarCSV" onAction="#onExportarCSV" styleClass="primary-button" text="Exportar CSV" />
                <Button fx:id="btnExportarTXT" onAction="#onExportarTXT" styleClass="secondary-button" text="Exportar TXT" />
                <Button fx:id="btnExportarKardex" onAction="#onExportarKardex" styleClass="primary-button" text="Exportar Kardex" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
