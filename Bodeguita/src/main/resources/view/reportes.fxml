<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bodega.controller.ReporteController">
    <top>
        <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #E0E0E0;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10" />
            </padding>
            <children>
                <Label text="Gestión de Reportes" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" alignment="CENTER">
            <padding>
                <Insets top="10" bottom="10" />
            </padding>
            <children>
                <!-- Selección del Reporte -->
                <HBox spacing="10" alignment="CENTER">
                    <children>
                        <Label text="Tipo de Reporte:" />
                        <ComboBox fx:id="comboTipoReporte" promptText="Seleccionar tipo de reporte" />
                    </children>
                </HBox>

                <!-- Filtros Adicionales -->
                <HBox spacing="10" alignment="CENTER">
                    <children>
                        <Label text="Filtro Producto:" />
                        <ComboBox fx:id="comboProducto" promptText="Seleccionar producto" />

                        <Label text="Filtro Proveedor:" />
                        <ComboBox fx:id="comboProveedor" promptText="Seleccionar proveedor" />

                        <Label text="Fecha Desde:" />
                        <DatePicker fx:id="dateDesde" />

                        <Label text="Fecha Hasta:" />
                        <DatePicker fx:id="dateHasta" />
                    </children>
                </HBox>

                <!-- Botones de Exportación -->
                <HBox spacing="20" alignment="CENTER">
                    <padding>
                        <Insets top="10" bottom="10" />
                    </padding>
                    <children>
                        <Button fx:id="btnExportarCSV" text="Exportar CSV" onAction="#onExportarCSV" />
                        <Button fx:id="btnExportarTXT" text="Exportar TXT" onAction="#onExportarTXT" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>