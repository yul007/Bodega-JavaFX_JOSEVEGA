<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.0"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bodega.controller.SalidaController">
    <top>
        <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #E0E0E0; -fx-padding: 10px;">
            <children>
                <Label text="Gestión de Salidas / Ventas" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="10" alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10" />
            </padding>
            <children>
                <!-- Formulario Cabecera -->
                <GridPane hgap="10" vgap="10" alignment="CENTER">
                    <columnConstraints>
                        <ColumnConstraints minWidth="130.0" />
                        <ColumnConstraints minWidth="200.0" />
                    </columnConstraints>
                    <children>
                        <Label text="Cliente:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <ComboBox fx:id="comboCliente" promptText="Seleccionar cliente"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Fecha:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <DatePicker fx:id="dateFecha"
                                    GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Número de Factura:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="txtNumeroFactura"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </children>
                </GridPane>

                <!-- Detalle Venta -->
                <VBox spacing="10" alignment="CENTER">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10" />
                    </padding>
                    <children>
                        <TableView fx:id="detalleTable" style="-fx-pref-width: 600;">
                            <columns>
                                <TableColumn text="Producto" fx:id="colProducto" />
                                <TableColumn text="Cantidad" fx:id="colCantidad" />
                                <TableColumn text="Precio Unitario" fx:id="colPrecioUnitario" />
                                <TableColumn text="Subtotal" fx:id="colSubtotal" />
                            </columns>
                        </TableView>

                        <HBox spacing="10" alignment="CENTER">
                            <children>
                                <Label text="Producto:" />
                                <ComboBox fx:id="comboProducto" promptText="Seleccionar producto" />

                                <Label text="Cantidad:" />
                                <TextField fx:id="txtCantidad" />

                                <Label text="Precio Unitario:" />
                                <TextField fx:id="txtPrecioUnitario" />

                                <Button fx:id="btnAgregarDetalle" text="Agregar" onAction="#onAgregarDetalle" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <!-- Resumen / Totales -->
                <HBox spacing="20" alignment="CENTER">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10" />
                    </padding>
                    <children>
                        <Label fx:id="lblSubtotal" text="Subtotal: $0.00" />
                        <Label fx:id="lblIva" text="IVA (12%): $0.00" />
                        <Label fx:id="lblTotal" text="Total: $0.00" />
                    </children>
                </HBox>

                <!-- Botones -->
                <HBox spacing="20" alignment="CENTER">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10" />
                    </padding>
                    <children>
                        <Button fx:id="btnGenerarFactura" text="Generar Factura" onAction="#onGenerarFactura" />
                        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
