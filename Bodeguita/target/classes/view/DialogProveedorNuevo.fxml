<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21.0.0"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bodega.controller.DialogProveedorNuevoController"
      spacing="10">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10" />
    </padding>
    <children>
        <Label text="RUC:" />
        <TextField fx:id="txtRuc" />

        <Label text="Nombre:" />
        <TextField fx:id="txtNombre" />

        <Label text="Contacto:" />
        <TextField fx:id="txtContacto" />

        <Label text="Teléfono:" />
        <TextField fx:id="txtTelefono" />

        <Label text="Email:" />
        <TextField fx:id="txtEmail" />

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <children>
                <Button text="Guardar" onAction="#onGuardar" />
                <Button text="Cancelar" onAction="#onCancelar" />
            </children>
        </HBox>
    </children>
</VBox>
