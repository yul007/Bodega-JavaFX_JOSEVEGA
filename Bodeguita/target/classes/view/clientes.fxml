<BorderPane prefHeight="650.0" prefWidth="1000.0" styleClass="module-shell" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <VBox spacing="4.0" styleClass="header-bar">
            <padding>
                <Insets bottom="18.0" left="28.0" right="28.0" top="18.0" />
            </padding>
            <Label styleClass="screen-title" text="Clientes" />
            <Label styleClass="screen-subtitle" text="Datos de clientes para notas de salida" />
        </VBox>
    </top>
    <center>
        <VBox spacing="12.0" styleClass="module-content">
            <Label styleClass="screen-subtitle" text="Modulo listo para conectar CRUD de clientes." />
        </VBox>
    </center>
</BorderPane>
