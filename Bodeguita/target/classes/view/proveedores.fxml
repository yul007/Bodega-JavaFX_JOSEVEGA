<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bodega.controller.ProveedorController">
    <top>
        <HBox alignment="CENTER" spacing="10" styleClass="header-bar">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <children>
                <Label styleClass="screen-title" text="Gestión de Proveedores" />
            </children>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets bottom="10" top="10" />
            </padding>
            <children>
                <TableView fx:id="proveedorTable" style="-fx-pref-width: 600;">
                    <columns>
                        <TableColumn fx:id="colRuc" text="RUC" />
                        <TableColumn fx:id="colNombre" text="Nombre" />
                        <TableColumn fx:id="colContacto" text="Contacto" />
                        <TableColumn fx:id="colTelefono" text="Teléfono" />
                        <TableColumn fx:id="colEmail" text="Email" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER" spacing="10">
                    <padding>
                        <Insets bottom="10" top="10" />
                    </padding>
                    <children>
                        <Button fx:id="btnNuevoProveedor" onAction="#onNuevoProveedor" text="Nuevo" />
                        <Button fx:id="btnEditarProveedor" onAction="#onEditarProveedor" text="Editar" />
                        <Button fx:id="btnInactivarProveedor" onAction="#onInactivarProveedor" text="Inactivar" />
                        <Button fx:id="btnRefrescar" onAction="#onRefrescar" text="Refrescar" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
